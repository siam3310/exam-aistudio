{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Taxonomy": {
      "title": "Taxonomy",
      "description": "User's class, subject, and chapter hierarchy",
      "type": "object",
      "properties": {
        "classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "subjects": {
          "type": "object",
          "description": "Map of className to array of subjects"
        },
        "chapters": {
          "type": "object",
          "description": "Map of className_subject to array of chapters"
        }
      },
      "required": ["classes", "subjects", "chapters"]
    },
    "Question": {
      "title": "Question",
      "description": "A multiple-choice question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "options": {
          "type": "object",
          "properties": {
            "a": { "type": "string" },
            "b": { "type": "string" },
            "c": { "type": "string" },
            "d": { "type": "string" }
          },
          "required": ["a", "b", "c", "d"]
        },
        "answer": { "type": "string", "enum": ["a", "b", "c", "d"] },
        "className": { "type": "string" },
        "subject": { "type": "string" },
        "chapter": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["id", "text", "options", "answer", "className", "subject", "chapter", "difficulty", "createdAt", "authorUid"]
    },
    "Exam": {
      "title": "Exam",
      "description": "A saved question paper",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionName": { "type": "string" },
        "examName": { "type": "string" },
        "className": { "type": "string" },
        "subject": { "type": "string" },
        "fullMarks": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "examQuestions": {
          "type": "array",
          "items": { "$ref": "#/entities/Question" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "examName", "examQuestions", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "users/{userId}/settings/taxonomy": {
      "schema": { "$ref": "#/entities/Taxonomy" },
      "description": "User's taxonomy hierarchy"
    },
    "users/{userId}/questions/{questionId}": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "Questions created by the user"
    },
    "users/{userId}/exams/{examId}": {
      "schema": { "$ref": "#/entities/Exam" },
      "description": "Saved question papers"
    }
  }
}
